# Document Intelligence Refinery — Environment Variables
# Copy this file to .env and fill in your API keys

# Required for Strategy C (Vision Extractor) and Query Agent LLM synthesis
# Get a free API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Override refinery artifact directory
# REFINERY_DIR=.refinery
